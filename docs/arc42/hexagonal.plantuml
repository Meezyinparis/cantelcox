@startuml
title 5.2 — Structure interne du commerce-service (hexagonal léger)

skinparam packageStyle rectangle
skinparam componentStyle uml2
skinparam shadowing false

package "Adapters d'entrée" {
  component "commerce_api.py\nRoutes REST Flask" as API
  component "controllers/\nplan, line, order,\nusage, invoice" as Controllers
}

package "Application\n(cas d'utilisation)" {
  component "commands/\nécritures métier" as Commands
  component "queries/\nlectures métier" as Queries
}

package "Domaine" {
  component "Plan" as Plan
  component "MobileLine\nMSISDN" as MobileLine
  component "Order" as Order
  component "OrderItem" as OrderItem
  component "UsageRecord" as Usage
  component "Invoice" as Invoice
}

package "Adapters de sortie\nInfrastructure" {
  component "db.py\nSQLAlchemy session" as DBAdapter
  component "Redis client\ncache catalogue / usage" as RedisAdapter
  component "HTTP client\nCustomer Identity" as IdentityAdapter
}

database "MySQL\ncommerce_db" as MySQL
database "Redis" as Redis
component "customer-identity-service" as Identity

API --> Controllers

Controllers --> Commands : opérations d'écriture
Controllers --> Queries : opérations de lecture

Commands --> Plan
Commands --> MobileLine
Commands --> Order
Commands --> OrderItem
Commands --> Usage
Commands --> Invoice

Queries --> Plan
Queries --> MobileLine
Queries --> Order
Queries --> Usage
Queries --> Invoice

Order --> OrderItem
OrderItem --> Plan
MobileLine --> Plan
Usage --> MobileLine
Invoice --> MobileLine

Commands --> DBAdapter
Queries --> DBAdapter
Queries --> RedisAdapter
Commands --> IdentityAdapter

DBAdapter --> MySQL
RedisAdapter --> Redis
IdentityAdapter --> Identity : validation auth / client

@enduml