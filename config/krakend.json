{
  "version": 3,
  "name": "CanTelcoX API Gateway",
  "timeout": "3s",
  "cache_ttl": "300s",
  "port": 8080,
  "endpoints": [
    {
      "endpoint": "/health",
      "method": "GET",
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/health",
          "host": ["http://commerce_service:5002"],
          "encoding": "no-op"
        }
      ]
    },
    {
      "endpoint": "/v1/identity/health",
      "method": "GET",
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/health",
          "host": ["http://customer_identity_service:5001"],
          "encoding": "no-op"
        }
      ]
    },
    {
      "endpoint": "/v1/customers/register",
      "method": "POST",
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/v1/customers/register",
          "host": ["http://customer_identity_service:5001"],
          "encoding": "no-op"
        }
      ]
    },
    {
      "endpoint": "/v1/customers/{customer_id}",
      "method": "GET",
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/v1/customers/{customer_id}",
          "host": ["http://customer_identity_service:5001"],
          "encoding": "no-op"
        }
      ]
    },
    {
      "endpoint": "/v1/auth/mfa/request",
      "method": "POST",
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/v1/auth/mfa/request",
          "host": ["http://customer_identity_service:5001"],
          "encoding": "no-op"
        }
      ]
    },
    {
      "endpoint": "/v1/auth/mfa/verify",
      "method": "POST",
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/v1/auth/mfa/verify",
          "host": ["http://customer_identity_service:5001"],
          "encoding": "no-op"
        }
      ]
    },
    {
      "endpoint": "/v1/catalog/plans",
      "method": "GET",
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/v1/catalog/plans",
          "host": ["http://commerce_service:5002"],
          "encoding": "no-op"
        }
      ],
      "extra_config": {
        "qos/ratelimit/router": {
          "max_rate": 100,
          "every": "1m"
        }
      }
    },
    {
      "endpoint": "/v1/catalog/plans/{plan_id}",
      "method": "GET",
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/v1/catalog/plans/{plan_id}",
          "host": ["http://commerce_service:5002"],
          "encoding": "no-op"
        }
      ]
    },
    {
      "endpoint": "/v1/lines/activate",
      "method": "POST",
      "input_headers": ["Authorization", "Content-Type"],
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/v1/lines/activate",
          "host": ["http://commerce_service:5002"],
          "encoding": "no-op"
        }
      ]
    },
    {
      "endpoint": "/v1/lines/{line_id}",
      "method": "GET",
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/v1/lines/{line_id}",
          "host": ["http://commerce_service:5002"],
          "encoding": "no-op"
        }
      ]
    },
    {
      "endpoint": "/v1/customers/{customer_id}/lines",
      "method": "GET",
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/v1/customers/{customer_id}/lines",
          "host": ["http://commerce_service:5002"],
          "encoding": "no-op"
        }
      ]
    },
    {
      "endpoint": "/v1/orders",
      "method": "POST",
      "input_headers": ["Authorization", "Idempotency-Key", "Content-Type"],
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/v1/orders",
          "host": ["http://commerce_service:5002"],
          "encoding": "no-op"
        }
      ],
      "extra_config": {
        "qos/ratelimit/router": {
          "max_rate": 100,
          "every": "1m"
        }
      }
    },
    {
      "endpoint": "/v1/orders/{order_id}",
      "method": "GET",
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/v1/orders/{order_id}",
          "host": ["http://commerce_service:5002"],
          "encoding": "no-op"
        }
      ]
    },
    {
      "endpoint": "/v1/usage/{line_id}",
      "method": "GET",
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/v1/usage/{line_id}",
          "host": ["http://commerce_service:5002"],
          "encoding": "no-op"
        }
      ]
    },
    {
      "endpoint": "/v1/invoices/{invoice_id}",
      "method": "GET",
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/v1/invoices/{invoice_id}",
          "host": ["http://commerce_service:5002"],
          "encoding": "no-op"
        }
      ]
    },
    {
      "endpoint": "/v1/lines/{line_id}/invoices",
      "method": "GET",
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/v1/lines/{line_id}/invoices",
          "host": ["http://commerce_service:5002"],
          "encoding": "no-op"
        }
      ]
    },
    {
      "endpoint": "/metrics",
      "method": "GET",
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/metrics",
          "host": ["http://commerce_service:5002"],
          "encoding": "no-op"
        }
      ]
    }
  ]
}
